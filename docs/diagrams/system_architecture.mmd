flowchart LR
    subgraph H["esp_hardware (Slave)"]
        HS["sensor_task<br/>ADC · DHT · GPIO · Ultrasonic"]
        HC["comm_task<br/>UART2 framing"]
        HA["actuator_task<br/>Pump · Fan · Servo · LED · LCD"]
    end

    subgraph L["esp_logic (Master)"]
        LC["comm_task<br/>UART2 framing"]
        CTRL["control_task<br/>State machine and control logic"]
        MON["monitor_task<br/>Stale data detection"]
        SER["serial_task<br/>Profile via serial"]
        WIFI["wifi_task<br/>SoftAP · HTTP · Web UI"]
    end

    SENSORS["Sensors"] --> HS
    HS -->|sensor data| HC
    HC <-->|UART2 frames| LC
    HC -->|actuator command| HA
    HA --> ACTS["Actuators"]
    LC <-->|sensor / command| CTRL
    MON -->|safe state signal| CTRL
    SER -->|profile| CTRL
    WIFI -->|profile| CTRL
    WIFI --> UI["Browser UI"]
