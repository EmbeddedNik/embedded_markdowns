flowchart TD
    START["Start control cycle"] --> FRESH{"Fresh sensor<br/>data available?"}
    FRESH -- no --> SAFE["Publish safe command<br/>all outputs off, REFILL display"]
    FRESH -- yes --> SNAP["Copy sensor snapshot"]

    SNAP --> WATER["Update water state<br/>OK / REFILL with hysteresis"]
    WATER --> LIGHT["Update day/night state<br/>LDR with confirmation timer"]
    LIGHT --> TEMP{"Temp and humidity<br/>valid?"}
    TEMP -- yes --> FAN["Calculate fan command<br/>from active profile thresholds"]
    TEMP -- no --> FANOFF["Fan off"]

    FAN --> OUTPUTS["Set servo and LED<br/>from current light state"]
    FANOFF --> OUTPUTS
    OUTPUTS --> PUMP["Set pump<br/>from button request"]
    PUMP --> ALARM["Update PIR alarm<br/>night mode only"]
    ALARM --> PUB["Publish actuator command"]
    SAFE --> PUB
