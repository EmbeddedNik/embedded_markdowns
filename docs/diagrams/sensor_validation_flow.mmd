flowchart TD
    START["sensor_task cycle"] --> ADC["Read ADC sensors<br/>water level and LDR"]
    ADC --> ROC["Rate-of-change check<br/>reject implausible jumps"]
    ROC --> DIG["Read digital inputs<br/>PIR and button"]
    DIG --> US["Read ultrasonic distance<br/>with timeout guard"]
    US --> DHT{"DHT read interval<br/>reached?"}
    DHT -- yes --> DHTR["Read DHT sensor<br/>retry once on failure"]
    DHT -- no --> REUSE["Reuse previous<br/>DHT values"]
    DHTR --> PLAUS["Apply plausibility bounds<br/>preserve last good value on error"]
    REUSE --> PLAUS
    PLAUS --> PUB["Publish sensor snapshot"]
    PUB --> LOG{"Log interval or<br/>error transition?"}
    LOG -- yes --> SERIAL["Write serial log"]
    LOG -- no --> END["Wait for next cycle"]
    SERIAL --> END
