flowchart TD
    START["actuator_task cycle"] --> CMD{"New command<br/>in queue?"}
    CMD -- yes --> APPLY["Use new command"]
    CMD -- no --> KEEP["Keep previous command"]

    APPLY --> FAN["Set fan speed"]
    KEEP --> FAN
    FAN --> SERVO["Move servo to target<br/>Release PWM after hold time"]

    SERVO --> PUMP{"Pump<br/>requested?"}
    PUMP -- yes --> LIMIT{"Max on-time<br/>reached?"}
    LIMIT -- no --> PON["Pump on"]
    LIMIT -- yes --> POFF["Force pump off<br/>Start cooldown"]
    PUMP -- no --> POFF2["Pump off"]

    PON --> OUT["Apply buzzer and LED<br/>Refresh LCD"]
    POFF --> OUT
    POFF2 --> OUT
    OUT --> END["Wait for next cycle"]
